<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingBottom="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📚 Edukasi"
                android:textColor="@color/teal_primary"
                android:textSize="11sp"
                android:textAllCaps="true"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pusat Pengetahuan"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="4dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pelajari cara mengenali, mencegah, dan mengatasi perundungan."
                android:textColor="@color/text_secondary"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- Search Bar -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="16dp"
            app:startIconDrawable="@android:drawable/ic_menu_search"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="@color/divider">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Cari artikel…"
                android:imeOptions="actionSearch"
                android:inputType="text"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Category Filter Chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingHorizontal="20dp"
            android:layout_marginBottom="16dp">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSemua"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Semua"
                    android:checkable="true"
                    android:checked="true"
                    android:layout_marginEnd="8dp"/>
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipTips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tips Pencegahan"
                    android:checkable="true"
                    android:layout_marginEnd="8dp"/>
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipHukum"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hukum"
                    android:checkable="true"
                    android:layout_marginEnd="8dp"/>
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPsikologi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Psikologi"
                    android:checkable="true"/>
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Featured Article Banner -->
        <androidx.cardview.widget.CardView
            style="@style/Widget.RuangAman.Card"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/teal_primary">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="bottom"
                android:padding="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ARTIKEL UNGGULAN"
                    android:textColor="#CCffffff"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:layout_marginBottom="6dp"/>
                <TextView
                    android:id="@+id/tvFeaturedTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mengenali Tanda-Tanda Perundungan di Sekolah"
                    android:textColor="@color/surface_white"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:maxLines="2"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Section Title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Semua Artikel"
                android:textStyle="bold"
                android:textSize="17sp"
                android:textColor="@color/text_primary"/>
            <TextView
                android:id="@+id/tvJumlahArtikel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- Empty State -->
        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/empty_artikel"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:padding="40dp"
            android:visibility="gone"/>

        <!-- Articles RecyclerView: id=rvArticles to match EducationFragment.kt -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvArticles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"/>

    </LinearLayout>
</ScrollView>