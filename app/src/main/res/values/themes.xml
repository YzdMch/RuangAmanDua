<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.RuangAman" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/teal_primary</item>
        <item name="colorPrimaryVariant">@color/teal_dark</item>
        <item name="colorOnPrimary">@color/surface_white</item>
        <item name="colorSecondary">@color/teal_light</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="Theme.RuangAman.Splash" parent="Theme.RuangAman">
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="Widget.RuangAman.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/teal_primary</item>
        <item name="android:textColor">@color/surface_white</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="Widget.RuangAman.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusBottomEnd">10dp</item>
        <item name="boxCornerRadiusBottomStart">10dp</item>
        <item name="boxCornerRadiusTopEnd">10dp</item>
        <item name="boxCornerRadiusTopStart">10dp</item>
        <item name="boxStrokeColor">@color/divider</item>
        <item name="hintTextColor">@color/text_hint</item>
    </style>

    <style name="Widget.RuangAman.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/surface_white</item>
    </style>
</resources>