<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="20dp">

        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="4dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="🛡️ RuangAman"
                android:textColor="@color/teal_primary" android:textSize="18sp" android:textStyle="bold"/>
            <ImageButton android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:src="@drawable/ic_notification" android:background="?attr/selectableItemBackgroundBorderless"/>
        </LinearLayout>

        <TextView android:id="@+id/tvGreeting" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Halo, Pengguna!"
            android:textSize="22sp" android:textStyle="bold" android:textColor="@color/text_primary"
            android:layout_marginBottom="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Kamu berada di ruang yang aman. Kami di sini untuk mendengarmu."
            android:textColor="@color/text_secondary" android:layout_marginBottom="20dp"/>

        <!-- Lapor Card -->
        <androidx.cardview.widget.CardView style="@style/Widget.RuangAman.Card"
            android:id="@+id/cardLaporSekarang"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" app:cardBackgroundColor="@color/teal_primary">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:padding="20dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Butuh Bantuan?" android:textColor="#CCffffff" android:textSize="13sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Lapor Sekarang" android:textColor="@color/surface_white"
                        android:textSize="20sp" android:textStyle="bold"/>
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📣" android:textSize="32sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Stats -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="16dp">
            <androidx.cardview.widget.CardView style="@style/Widget.RuangAman.Card"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginEnd="8dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📋 Dalam Proses" android:textColor="@color/text_secondary" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvLaporanProses" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0 Laporan"
                        android:textStyle="bold" android:textSize="18sp" android:textColor="@color/text_primary"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView style="@style/Widget.RuangAman.Card"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginStart="8dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="✅ Selesai" android:textColor="@color/text_secondary" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvLaporanSelesai" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0 Laporan"
                        android:textStyle="bold" android:textSize="18sp" android:textColor="@color/text_primary"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Kontak Darurat -->
        <androidx.cardview.widget.CardView style="@style/Widget.RuangAman.Card"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Kontak Darurat"
                        android:textStyle="bold" android:textSize="16sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="*" android:textColor="@color/red_danger" android:textSize="20sp"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGuruBK"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginEnd="8dp"
                        android:text="📞 Guru BK"
                        app:backgroundTint="#FFEBEE"
                        android:textColor="@color/red_danger"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPusatKrisis"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="8dp"
                        android:text="🆘 Pusat Krisis"
                        app:backgroundTint="@color/teal_light"
                        android:textColor="@color/teal_primary"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Tips Hari Ini -->
        <androidx.cardview.widget.CardView style="@style/Widget.RuangAman.Card"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📖 TIPS HARI INI" android:textColor="@color/text_secondary"
                    android:textSize="11sp" android:layout_marginBottom="4dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Suaramu Berharga. Melapor adalah langkah pertama menuju perubahan."
                    android:textStyle="bold" android:textSize="15sp" android:layout_marginBottom="4dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Jangan pernah merasa sendiri. Kami siap mendukungmu."
                    android:textColor="@color/text_secondary"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Edukasi Populer -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Edukasi Populer"
                android:textStyle="bold" android:textSize="17sp"/>
            <TextView android:id="@+id/tvLihatSemua" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Lihat Semua"
                android:textColor="@color/teal_primary" android:textSize="13sp"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvEdukasi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"/>
    </LinearLayout>
</ScrollView>