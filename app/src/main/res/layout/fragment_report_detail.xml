<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- Top App Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">
            <ImageButton
                android:id="@+id/ivBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_revert"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Kembali"
                android:layout_marginEnd="8dp"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Detail Laporan"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/text_primary"/>
        </LinearLayout>

        <!-- Report ID & Status Header -->
        <androidx.cardview.widget.CardView
            style="@style/Widget.RuangAman.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/teal_primary">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <TextView
                    android:id="@+id/tvReportId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ID Laporan: RA-00000000"
                    android:textColor="@color/surface_white"
                    android:textSize="13sp"
                    android:layout_marginBottom="8dp"/>
                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Terkirim"
                    android:textColor="@color/surface_white"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:layout_marginBottom="8dp"/>
                <TextView
                    android:id="@+id/tvTanggalKirim"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dikirim pada -"
                    android:textColor="#CCffffff"
                    android:textSize="12sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Progress Tracker -->
        <androidx.cardview.widget.CardView
            style="@style/Widget.RuangAman.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PROGRES LAPORAN"
                    android:textColor="@color/text_hint"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:layout_marginBottom="16dp"/>

                <!-- Steps horizontal -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <View
                            android:id="@+id/stepTerkirim"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:background="@drawable/bg_chip_topic"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Terkirim"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                    <View
                        android:layout_width="0dp"
                        android:layout_height="2dp"
                        android:layout_weight="0.5"
                        android:background="@color/divider"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <View
                            android:id="@+id/stepDitinjau"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:background="@drawable/bg_chip_topic"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ditinjau"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                    <View
                        android:layout_width="0dp"
                        android:layout_height="2dp"
                        android:layout_weight="0.5"
                        android:background="@color/divider"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <View
                            android:id="@+id/stepInvestigasi"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:background="@drawable/bg_chip_topic"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Investigasi"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                    <View
                        android:layout_width="0dp"
                        android:layout_height="2dp"
                        android:layout_weight="0.5"
                        android:background="@color/divider"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <View
                            android:id="@+id/stepSelesai"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:background="@drawable/bg_chip_topic"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Selesai"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Detail Info Card -->
        <androidx.cardview.widget.CardView
            style="@style/Widget.RuangAman.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DETAIL LAPORAN"
                    android:textColor="@color/text_hint"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:layout_marginBottom="16dp"/>

                <!-- Row: Jenis Bullying -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Jenis Perundungan"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"/>
                    <TextView
                        android:id="@+id/tvJenisBullying"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:textSize="13sp"/>
                </LinearLayout>

                <!-- Row: Lokasi -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Lokasi"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"/>
                    <TextView
                        android:id="@+id/tvLokasi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:textSize="13sp"/>
                </LinearLayout>

                <!-- Row: Anonim -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Dilaporkan Anonim"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"/>
                    <TextView
                        android:id="@+id/tvAnonim"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:textSize="13sp"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>