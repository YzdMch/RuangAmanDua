<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    style="@style/Widget.RuangAman.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="12dp" android:gravity="center_vertical">

        <View android:layout_width="64dp" android:layout_height="64dp"
            android:background="@color/teal_light" android:layout_marginEnd="12dp"/>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/tvJudul" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textStyle="bold"
                android:textSize="14sp" android:textColor="@color/text_primary"
                android:maxLines="2" android:layout_marginBottom="4dp"/>
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:id="@+id/tvKategori" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="@color/teal_primary"
                    android:textSize="11sp" android:layout_marginEnd="8dp"/>
                <TextView android:id="@+id/tvWaktuBaca" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="@color/text_secondary"
                    android:textSize="11sp" android:layout_marginEnd="8dp"/>
                <TextView android:id="@+id/tvViewCount" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="@color/text_secondary"
                    android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>